{
  "info": {
    "name": "TravelSphere Phase 6 API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Core endpoints for Phase 2-6 verification including auth, booking, transaction, and admin analytics."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api/v1"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "customerToken",
      "value": ""
    },
    {
      "key": "bookingId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/health",
          "host": ["http://localhost:4000"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Auth - Admin Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@travelsphere.dev\",\n  \"password\": \"Password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Auth - Customer Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer@travelsphere.dev\",\n  \"password\": \"Password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Packages - List",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/packages?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["packages"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Bookings - Customer My Bookings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{customerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/bookings/my",
          "host": ["{{baseUrl}}"],
          "path": ["bookings", "my"]
        }
      }
    },
    {
      "name": "Transactions - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{customerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"booking_id\": \"{{bookingId}}\",\n  \"amount\": 1200,\n  \"method\": \"card\",\n  \"status\": \"success\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/transactions",
          "host": ["{{baseUrl}}"],
          "path": ["transactions"]
        }
      }
    },
    {
      "name": "Transactions - Get By Booking",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/transactions/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["transactions", "{{bookingId}}"]
        }
      }
    },
    {
      "name": "Admin - Bookings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/bookings?page=1&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "bookings"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "Admin - Analytics Overview",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/analytics/overview",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "analytics", "overview"]
        }
      }
    },
    {
      "name": "Admin - Packages",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/packages",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "packages"]
        }
      }
    },
    {
      "name": "Admin - Agents",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/agents",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "agents"]
        }
      }
    },
    {
      "name": "Admin - Customers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/customers",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "customers"]
        }
      }
    },
    {
      "name": "Admin - Transactions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/transactions",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "transactions"]
        }
      }
    }
  ]
}
