generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  agent
  admin
}

enum BookingStatus {
  pending
  confirmed
  open_for_agents
  assigned
  accepted
  rejected
  in_progress
  completed
  closed
  cancelled
}

enum AgentApplicationStatus {
  applied
  shortlisted
  selected
  rejected
  withdrawn
}

enum TransactionStatus {
  initiated
  success
  failed
  refunded
}

enum PayoutStatus {
  unpaid
  partial
  paid
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         Role
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  agentProfile AgentProfile?
  bookings     Booking[]

  @@index([role])
  @@map("users")
}

model AgentProfile {
  id            String          @id @default(cuid())
  userId        String          @unique
  agencyName    String
  bio           String?
  contactNumber String?
  isVerified    Boolean         @default(false)
  agentRating   Decimal         @default(5.0) @db.Decimal(5, 2)
  tripAssignedCount Int         @default(0)
  tripAcceptedCount Int         @default(0)
  tripRejectedCount Int         @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  packages      TravelPackage[]
  assignedBookings Booking[]    @relation("AssignedAgentBookings")
  applications  AgentApplication[]
  packageInterests PackageInterest[]

  @@map("agent_profiles")
}

model TravelPackage {
  id                    String    @id @default(cuid())
  agentId               String?
  title                 String
  destination           String?
  durationDays          Int
  price                 Decimal   @db.Decimal(10, 2)
  description           String
  bannerImage           String?
  category              String    @default("group_tours") // group_tours, personal_tours, couple_tours, etc.
  isActive              Boolean   @default(true)
  featuredRank          Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  agent                 AgentProfile? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  bookings              Booking[]
  interests             PackageInterest[]
  itineraries           PackageItinerary[]
  pricingOptions        PackagePricingOption[]
  departures            PackageDeparture[]
  inclusions            PackageInclusion[]
  addOns                PackageAddOn[]

  @@index([agentId])
  @@index([destination])
  @@index([category])
  @@map("travel_packages")
}

model Booking {
  id            String        @id @default(cuid())
  customerId    String
  packageId     String
  customerName  String?
  contactEmail  String?
  contactPhone  String?
  travelMessage String?
  assignedAgentId String?
  publishedAt   DateTime?
  bookingDate   DateTime      @default(now())
  travelDate    DateTime
  travelersCount Int
  status        BookingStatus @default(confirmed)
  totalAmount   Decimal       @db.Decimal(10, 2)
  agentPayout   Decimal?      @db.Decimal(10, 2)
  adminMargin   Decimal?      @db.Decimal(10, 2)
  payoutStatus  PayoutStatus  @default(unpaid)
  payoutPaidAmount Decimal?   @db.Decimal(10, 2)
  payoutTransactionReference String?
  payoutPaidAt  DateTime?
  agentDecisionRemark String?
  agentRequestRemark  String?
  agentRejectionReason String?
  feedbackRating Int?
  feedbackComment String?
  feedbackSubmittedAt DateTime?
  confirmedAt   DateTime?
  razorpayPaymentId String?
  razorpayOrderId   String?
  paymentDetails Json?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  completedAt   DateTime?
  closedAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  customer      User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  package       TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  assignedAgent AgentProfile? @relation("AssignedAgentBookings", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  transaction   Transaction?
  applications  AgentApplication[]

  @@index([customerId])
  @@index([packageId])
  @@index([assignedAgentId])
  @@index([status])
  @@index([bookingDate])
  @@index([travelDate])
  @@index([status, bookingDate])
  @@map("bookings")
}

model AgentApplication {
  id            String                 @id @default(cuid())
  bookingId     String
  agentId       String
  status        AgentApplicationStatus @default(applied)
  message       String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  selectedAt    DateTime?
  rejectedAt    DateTime?
  booking       Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  agent         AgentProfile           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([bookingId, agentId])
  @@index([bookingId, status])
  @@index([agentId, status])
  @@map("agent_applications")
}

model PackageInterest {
  id           String        @id @default(cuid())
  packageId    String
  agentId      String
  availability String        @default("available")
  message      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  package      TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  agent        AgentProfile  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([packageId, agentId])
  @@index([packageId])
  @@index([agentId])
  @@map("package_interests")
}

model Transaction {
  id                   String            @id @default(cuid())
  bookingId            String            @unique
  amount               Decimal           @db.Decimal(10, 2)
  paymentMethod        String
  status               TransactionStatus
  transactionReference String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  booking              Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

model PackageItinerary {
  id                String    @id @default(cuid())
  packageId         String
  dayNumber         Int
  title             String
  description       String
  morningActivity   String?
  afternoonActivity String?
  eveningActivity   String?
  nightActivity     String?
  locations         Json?     // Array of location strings
  activities        Json?     // Array of activities
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  package           TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([dayNumber])
  @@map("package_itineraries")
}

model PackagePricingOption {
  id        String    @id @default(cuid())
  packageId String
  roomType  String    // "sharing", "triple", "double", "single", "infant"
  price     Decimal   @db.Decimal(10, 2)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  package   TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, roomType])
  @@index([packageId])
  @@map("package_pricing_options")
}

model PackageDeparture {
  id             String    @id @default(cuid())
  packageId      String
  departureDate  DateTime
  availableSeats Int
  bookedSeats    Int       @default(0)
  price          Decimal   @db.Decimal(10, 2)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  package        TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([departureDate])
  @@map("package_departures")
}

model PackageInclusion {
  id          String    @id @default(cuid())
  packageId   String
  type        String    // "inclusion" or "exclusion"
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  package     TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([type])
  @@map("package_inclusions")
}

model PackageAddOn {
  id          String    @id @default(cuid())
  packageId   String
  title       String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  package     TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("package_addons")
}
