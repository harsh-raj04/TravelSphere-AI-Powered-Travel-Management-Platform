generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  agent
  admin
}

enum BookingStatus {
  pending
  confirmed
  open_for_agents
  assigned
  accepted
  rejected
  in_progress
  completed
  closed
  cancelled
}

enum AgentApplicationStatus {
  applied
  shortlisted
  selected
  rejected
  withdrawn
}

enum TransactionStatus {
  initiated
  success
  failed
  refunded
}

enum PayoutStatus {
  unpaid
  partial
  paid
}

enum WithdrawalStatus {
  pending
  processing
  completed
  failed
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

model User {
  id                String          @id @default(cuid())
  name              String
  email             String          @unique
  passwordHash      String
  role              Role
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  phone             String?
  dateOfBirth       DateTime?
  gender            String?
  city              String?
  state             String?
  languages         Json?
  travelPreferences Json?
  emergencyContact  Json?
  notificationPrefs Json?
  privacySettings   Json?
  referralCode      String?         @unique
  agentProfile      AgentProfile?
  bookings       Booking[]
  notifications  Notification[]
  supportTickets SupportTicket[]
  ticketMessages TicketMessage[] @relation("TicketMessageSender")
  customPackageRequests CustomPackageRequest[]
  aiChatConversations   AIChatConversation[]
  chatProfile           UserChatProfile?
  createdChatRooms      ChatRoom[]
  sentChatMessages      ChatMessage[]

  @@index([role])
  @@map("users")
}

model AgentProfile {
  id            String          @id @default(cuid())
  userId        String          @unique
  agencyName    String
  bio           String?
  contactNumber String?
  isVerified    Boolean         @default(false)
  agentRating   Decimal         @default(5.0) @db.Decimal(5, 2)
  tripAssignedCount Int         @default(0)
  tripAcceptedCount Int         @default(0)
  tripRejectedCount Int         @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  packages      TravelPackage[]
  assignedBookings Booking[]    @relation("AssignedAgentBookings")
  applications  AgentApplication[]
  packageInterests PackageInterest[]
  paymentMethods PaymentMethod[]
  withdrawals    AgentWithdrawal[]

  @@map("agent_profiles")
}

model TravelPackage {
  id                    String    @id @default(cuid())
  agentId               String?
  title                 String
  destination           String?
  durationDays          Int
  price                 Decimal   @db.Decimal(10, 2)
  description           String
  bannerImage           String?
  category              String    @default("group_tours") // group_tours, personal_tours, couple_tours, etc.
  tripStyle             String?   // beach, mountain, adventure, calm, heritage
  isActive              Boolean   @default(true)
  featuredRank          Int?
  rating                Float?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  agent                 AgentProfile? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  bookings              Booking[]
  interests             PackageInterest[]
  itineraries           PackageItinerary[]
  pricingOptions        PackagePricingOption[]
  departures            PackageDeparture[]
  inclusions            PackageInclusion[]
  addOns                PackageAddOn[]

  @@index([agentId])
  @@index([destination])
  @@index([category])
  @@map("travel_packages")
}

model Booking {
  id            String        @id @default(cuid())
  customerId       String
  packageId        String?
  customRequestId  String?
  customerName     String?
  contactEmail  String?
  contactPhone  String?
  travelMessage String?
  assignedAgentId String?
  publishedAt   DateTime?
  bookingDate   DateTime      @default(now())
  travelDate    DateTime
  travelersCount Int
  status        BookingStatus @default(confirmed)
  totalAmount   Decimal       @db.Decimal(10, 2)
  agentPayout   Decimal?      @db.Decimal(10, 2)
  adminMargin   Decimal?      @db.Decimal(10, 2)
  payoutStatus  PayoutStatus  @default(unpaid)
  payoutPaidAmount Decimal?   @db.Decimal(10, 2)
  payoutTransactionReference String?
  payoutPaidAt  DateTime?
  agentDecisionRemark String?
  agentRequestRemark  String?
  agentRejectionReason String?
  feedbackRating Int?
  feedbackComment String?
  feedbackSubmittedAt DateTime?
  confirmedAt   DateTime?
  razorpayPaymentId String?
  razorpayOrderId   String?
  paymentDetails Json?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  completedAt   DateTime?
  closedAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  customer      User                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  package       TravelPackage?        @relation(fields: [packageId], references: [id], onDelete: Cascade)
  customRequest CustomPackageRequest? @relation(fields: [customRequestId], references: [id], onDelete: SetNull)
  assignedAgent AgentProfile?         @relation("AssignedAgentBookings", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  transaction   Transaction?
  applications  AgentApplication[]

  @@index([customerId])
  @@index([packageId])
  @@index([assignedAgentId])
  @@index([status])
  @@index([bookingDate])
  @@index([travelDate])
  @@index([status, bookingDate])
  @@map("bookings")
}

model AgentApplication {
  id            String                 @id @default(cuid())
  bookingId     String
  agentId       String
  status        AgentApplicationStatus @default(applied)
  message       String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  selectedAt    DateTime?
  rejectedAt    DateTime?
  booking       Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  agent         AgentProfile           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([bookingId, agentId])
  @@index([bookingId, status])
  @@index([agentId, status])
  @@map("agent_applications")
}

model PackageInterest {
  id           String        @id @default(cuid())
  packageId    String
  agentId      String
  availability String        @default("available")
  message      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  package      TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  agent        AgentProfile  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([packageId, agentId])
  @@index([packageId])
  @@index([agentId])
  @@map("package_interests")
}

model Transaction {
  id                   String            @id @default(cuid())
  bookingId            String?           @unique
  amount               Decimal           @db.Decimal(10, 2)
  paymentMethod        String
  status               TransactionStatus
  transactionReference String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  booking              Booking?          @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

model PackageItinerary {
  id                String    @id @default(cuid())
  packageId         String
  dayNumber         Int
  title             String
  description       String
  morningActivity   String?
  afternoonActivity String?
  eveningActivity   String?
  nightActivity     String?
  locations         Json?     // Array of location strings
  activities        Json?     // Array of activities
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  package           TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([dayNumber])
  @@map("package_itineraries")
}

model PackagePricingOption {
  id        String    @id @default(cuid())
  packageId String
  roomType  String    // "sharing", "triple", "double", "single", "infant"
  price     Decimal   @db.Decimal(10, 2)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  package   TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, roomType])
  @@index([packageId])
  @@map("package_pricing_options")
}

model PackageDeparture {
  id             String    @id @default(cuid())
  packageId      String
  departureDate  DateTime
  availableSeats Int
  bookedSeats    Int       @default(0)
  price          Decimal   @db.Decimal(10, 2)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  package        TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([departureDate])
  @@map("package_departures")
}

model PackageInclusion {
  id          String    @id @default(cuid())
  packageId   String
  type        String    // "inclusion" or "exclusion"
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  package     TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([type])
  @@map("package_inclusions")
}

model PackageAddOn {
  id          String    @id @default(cuid())
  packageId   String
  title       String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  package     TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("package_addons")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'email_change' | 'phone_change'
  otpHash   String   // bcrypt hash of the 6-digit OTP
  newValue  String   // the new email or phone being verified
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, type])
  @@map("otp_verifications")
}

model RegistrationOtp {
  id        String   @id @default(cuid())
  email     String
  otpHash   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("registration_otps")
}

model PaymentMethod {
  id                String       @id @default(cuid())
  agentId           String
  agent             AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type              String       // 'bank_account' | 'upi' | 'card'
  accountHolderName String?
  accountNumber     String?      // last 4 digits only
  ifscCode          String?
  bankName          String?
  upiId             String?
  cardHolderName    String?
  cardLastFour      String?
  expiryDate        String?
  isDefault         Boolean      @default(false)
  isVerified        Boolean      @default(false)
  isDeleted         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  withdrawals       AgentWithdrawal[]

  @@index([agentId])
  @@map("payment_methods")
}

model AgentWithdrawal {
  id              String           @id @default(cuid())
  agentId         String
  agent           AgentProfile     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  paymentMethodId String?
  paymentMethod   PaymentMethod?   @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  amount          Decimal          @db.Decimal(10, 2)
  status          WithdrawalStatus @default(pending)
  transactionId   String           @unique
  methodSnapshot  Json?
  expectedAt      DateTime
  processedAt     DateTime?
  failureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([agentId])
  @@index([agentId, status])
  @@index([status])
  @@map("agent_withdrawals")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  entityId   String?
  entityType String?
  actionUrl  String?
  isRead     Boolean  @default(false)
  priority   String   @default("normal")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model SupportTicket {
  id              String          @id @default(cuid())
  ticketNumber    String          @unique
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userRole        String
  subject         String
  description     String
  issueType       String
  priority        TicketPriority  @default(medium)
  status          TicketStatus    @default(open)
  resolvedAt      DateTime?
  closedAt        DateTime?
  resolutionNotes String?
  messages        TicketMessage[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([userRole])
  @@index([ticketNumber])
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User          @relation("TicketMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderRole String
  message    String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

model TermsSection {
  id        String   @id @default(cuid())
  order     Int
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("terms_sections")
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  isActive    Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?

  @@index([email])
  @@map("newsletter_subscribers")
}

model CustomPackageRequest {
  id              String       @id @default(cuid())
  requestNumber   String       @unique
  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  name            String
  email           String
  phone           String?
  destination     String
  departureDate   String?
  duration        Int?
  adults          Int          @default(1)
  children        Int          @default(0)
  budget          String?
  tripType        String?
  accommodation   String?
  mealPlan        String?
  transport       String?
  interests       Json?
  specialRequests String?
  status          String       @default("pending")
  adminNote       String?
  itinerary       String?
  quotedPrice     Decimal?     @db.Decimal(10, 2)
  customerNote    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  razorpayOrderId   String?
  razorpayPaymentId String?
  bookingId         String?
  messages          CustomPackageMessage[]
  bookings          Booking[]

  @@index([userId])
  @@index([status])
  @@map("custom_package_requests")
}

model CustomPackageMessage {
  id         String               @id @default(cuid())
  requestId  String
  request    CustomPackageRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  senderRole String               // 'admin' | 'customer'
  message    String
  createdAt  DateTime             @default(now())

  @@index([requestId])
  @@map("custom_package_messages")
}

model AIChatConversation {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId       String    @unique
  type            String    @default("trip-planner") // 'trip-planner' | 'homepage-widget'
  title           String?
  messages        Json      @default("[]")
  messageCount    Int       @default(0)
  leadToBooking   Boolean   @default(false)
  bookingId       String?
  startedAt       DateTime  @default(now())
  lastMessageAt   DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([type])
  @@map("ai_chat_conversations")
}

// ─── Phase 4: Community Chat ───────────────────────────────────────────────────

model UserChatProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName          String   @unique
  avatar               String?
  bio                  String?
  isOnline             Boolean  @default(false)
  lastSeen             DateTime @default(now())
  status               String   @default("available")
  allowPrivateMessages Boolean  @default(true)
  showOnlineStatus     Boolean  @default(true)
  isBanned             Boolean  @default(false)
  banReason            String?
  banExpiresAt         DateTime?
  messagesSent         Int      @default(0)
  reputationScore      Int      @default(0)
  warnings             Json     @default("[]")
  notificationPrefs    Json?
  blockedUserIds       String[] @default([])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sentMessages ChatMessage[]
  memberships  ChatRoomMember[]

  @@index([userId])
  @@map("user_chat_profiles")
}

model ChatRoom {
  id               String   @id @default(cuid())
  type             String   // public|location|group|private
  name             String
  slug             String   @unique
  description      String?
  image            String?
  location         String?
  isActive         Boolean  @default(true)
  isPublic         Boolean  @default(true)
  maxParticipants  Int?
  allowInvites     Boolean  @default(true)
  allowFileUploads Boolean  @default(true)
  allowLinks       Boolean  @default(true)
  createdById      String?
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  lastActivityAt   DateTime @default(now())
  messageCount     Int      @default(0)
  pinnedMessageIds String[] @default([])

  messages ChatMessage[]
  members  ChatRoomMember[]

  @@index([slug])
  @@index([type])
  @@map("chat_rooms")
}

model ChatRoomMember {
  id           String          @id @default(cuid())
  roomId       String
  room         ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  profileId    String
  profile      UserChatProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role         String          @default("member")
  joinedAt     DateTime        @default(now())
  lastReadAt   DateTime        @default(now())
  mutedUntil   DateTime?
  isBanned     Boolean         @default(false)
  banReason    String?
  banExpiresAt DateTime?

  @@unique([roomId, profileId])
  @@index([roomId])
  @@index([profileId])
  @@map("chat_room_members")
}

model ChatMessage {
  id           String          @id @default(cuid())
  roomId       String
  room         ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId     String
  sender       UserChatProfile @relation(fields: [senderId], references: [id])
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  senderName   String
  senderAvatar String?
  messageType  String          @default("text")
  content      String
  replyToId    String?
  replyTo      ChatMessage?    @relation("Replies", fields: [replyToId], references: [id])
  replies      ChatMessage[]   @relation("Replies")
  mentions     String[]        @default([])
  reactions    Json            @default("[]")
  attachments  Json            @default("[]")
  isEdited     Boolean         @default(false)
  editedAt     DateTime?
  isDeleted    Boolean         @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  isFlagged    Boolean         @default(false)
  flaggedBy    Json            @default("[]")
  isPinned     Boolean         @default(false)
  pinnedBy     String?
  pinnedAt     DateTime?
  createdAt    DateTime        @default(now())

  @@index([roomId, createdAt])
  @@index([senderId])
  @@index([isFlagged])
  @@map("chat_messages")
}
