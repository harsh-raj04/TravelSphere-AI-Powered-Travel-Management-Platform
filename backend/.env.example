PORT=4000
NODE_ENV=development
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# PostgreSQL Connection
# Local: postgresql://user:password@localhost:5432/travelsphere
# AWS RDS with SSL: postgresql://user:password@<rds-endpoint>:5432/travelsphere?sslmode=require
# Connection pooling for better performance (handled by Prisma Client)
DATABASE_URL=postgresql://user:password@localhost:5432/travelsphere

